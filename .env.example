# Pass this file to Flutter with --dart-define-from-file=.env.
# Set to true to run the bundled recorded video instead of the device camera.
USE_RECORDED_VIDEO=false
# Set only in deterministic acceptance lanes. Production always captures the
# microphone and never writes its PCM stream to a file.
USE_RECORDED_AUDIO=false

# Pinned Qwen3-0.6B Q4_K_M artifact.
QWEN_MODEL_ID=unsloth/Qwen3-0.6B-GGUF
QWEN_MODEL_URL=https://huggingface.co/unsloth/Qwen3-0.6B-GGUF/resolve/272676c9e0eb9f33a7719ba3d27482fbb445e801/Qwen3-0.6B-Q4_K_M.gguf?download=true
QWEN_MODEL_REVISION=272676c9e0eb9f33a7719ba3d27482fbb445e801
QWEN_MODEL_FILENAME=Qwen3-0.6B-Q4_K_M.gguf
QWEN_MODEL_SIZE_BYTES=396705472
QWEN_MODEL_SHA256=ac2d97712095a558e31573f62f466a3f9d93990898b0ec79d7c974c1780d524a
QWEN_MODEL_LICENSE=Apache-2.0
QWEN_DOWNLOAD_RESERVE_BYTES=67108864

# llama.cpp context and execution policy.
QWEN_CONTEXT_TOKENS=2048
QWEN_BATCH_TOKENS=512
QWEN_THREAD_COUNT=4
QWEN_GPU_LAYERS=99
# Fixed values seed a deterministic short-comment sequence; 2^32 - 1 stays random.
QWEN_RANDOM_SEED=4294967295

# Qwen prompt and sampling policy. The legacy QWEN_MANUAL_* key names configure
# both typed prompts and hands-free voice questions.
QWEN_SYSTEM_PROMPT=You are POV Agent, a helpful local assistant. Always answer in English.
QWEN_MANUAL_MAX_TOKENS=512
QWEN_MANUAL_TEMPERATURE=0.6
QWEN_MANUAL_TOP_P=0.95
QWEN_MANUAL_TOP_K=20
QWEN_MANUAL_MIN_P=0.0
QWEN_COMMENT_MAX_TOKENS=40
QWEN_COMMENT_TEMPERATURE=0.7
QWEN_COMMENT_TOP_P=0.8
QWEN_COMMENT_TOP_K=20
QWEN_COMMENT_MIN_P=0.0

