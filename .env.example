# sherpa-onnx streaming recognition and endpoint policy.
ASR_PROVIDER=cpu
ASR_THREAD_COUNT=2
ASR_SAMPLE_RATE=16000
ASR_FEATURE_DIMENSION=80
ASR_DECODING_METHOD=greedy_search
ASR_MAXIMUM_ACTIVE_PATHS=4
ASR_EMPTY_TRAILING_SILENCE_SECONDS=2.4
