ASR_MAXIMUM_UTTERANCE_SECONDS=15
ASR_WAKE_PHRASE=assistant
ASR_MAXIMUM_PENDING_AUDIO_CHUNKS=8
ASR_DEBUG=false

# Preferred system TTS locale. Selection tries this tag first, then installed
# en-US and en-GB system voices, without repeating a duplicate tag.
SYSTEM_SPEECH_LANGUAGE=en-US
