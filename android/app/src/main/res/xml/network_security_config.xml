<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- just_audio serves StreamAudioSource bytes through an in-process loopback
         proxy. Keep cleartext disabled for every non-loopback destination. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
